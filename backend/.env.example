# Docker Compose 使用的开发环境配置。
POSTGRES_DB=bid_system
POSTGRES_USER=bid_system
POSTGRES_PASSWORD=bid_system_dev
POSTGRES_PORT=5432
TZ=Asia/Shanghai

# Python 后端在宿主机运行时使用。
DATABASE_URL=postgresql+psycopg://bid_system:bid_system_dev@localhost:5432/bid_system

# Python 后端以后也放进同一个 Compose 网络时，主机名应使用服务名 postgres。
DATABASE_URL_DOCKER=postgresql+psycopg://bid_system:bid_system_dev@postgres:5432/bid_system

# MinIO 对象存储（仅用于本地开发）。
MINIO_ROOT_USER=bid_system
MINIO_ROOT_PASSWORD=bid_system_dev_secret
MINIO_BUCKET=bid-system
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Python 后端在宿主机运行时使用。
MINIO_ENDPOINT=localhost:9000
MINIO_SECURE=false

# Python 后端在 Compose 网络中运行时使用。
MINIO_ENDPOINT_DOCKER=minio:9000
