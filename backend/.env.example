# 应用环境：dev、test 或 prod。
APP_ENV=dev

# Docker Compose 使用的开发环境配置。
POSTGRES_DB=bid_system
POSTGRES_USER=bid_system
POSTGRES_PASSWORD=bid_system_dev
POSTGRES_PORT=5432
TZ=Asia/Shanghai

# Python 后端在宿主机运行时使用。
DATABASE_URL=postgresql+psycopg://bid_system:bid_system_dev@localhost:5432/bid_system
# 集成测试必须使用独立数据库，测试夹具会拒绝与 DATABASE_URL 相同的地址。
TEST_DATABASE_URL=postgresql+psycopg://bid_system:bid_system_dev@localhost:5432/bid_system_test

# Python 后端以后也放进同一个 Compose 网络时，主机名应使用服务名 postgres。
DATABASE_URL_DOCKER=postgresql+psycopg://bid_system:bid_system_dev@postgres:5432/bid_system
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT_SECONDS=30

# Redis 仅承载队列、缓存、锁和临时状态。
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
REDIS_URL_DOCKER=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=20

# MinIO 对象存储（仅用于本地开发）。
MINIO_ROOT_USER=bid_system
MINIO_ROOT_PASSWORD=bid_system_dev_secret
MINIO_BUCKET=bid-system
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Python 后端在宿主机运行时使用。
MINIO_ENDPOINT=localhost:9000
MINIO_SECURE=false

# Python 后端在 Compose 网络中运行时使用。
MINIO_ENDPOINT_DOCKER=minio:9000

# 可选 LLM/OCR 客户端。启用时必须从环境或密钥系统注入完整配置。
LLM_ENABLED=false
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_PROBE_ON_STARTUP=false

OCR_ENABLED=false
OCR_BASE_URL=
OCR_API_KEY=
OCR_MODEL=
OCR_PROBE_ON_STARTUP=false

# 外部调用与生命周期超时，单位均为秒。
HTTP_TIMEOUT_SECONDS=30
STARTUP_CONNECT_TIMEOUT_SECONDS=10
SHUTDOWN_TIMEOUT_SECONDS=10

LOG_LEVEL=INFO
LOG_JSON=false

# HTTP API 暴露策略及传输限制。列表值使用 JSON 数组格式。
API_TITLE=Bid System API
API_DESCRIPTION=HTTP API for the bid agent platform.
API_PREFIX=/api/v1
API_CORS_ORIGINS=[]
API_TRUSTED_HOSTS=["localhost","127.0.0.1"]
API_GZIP_MINIMUM_SIZE_BYTES=1024
API_MAX_REQUEST_BODY_BYTES=10485760
API_READINESS_TIMEOUT_SECONDS=3
API_HSTS_ENABLED=false
