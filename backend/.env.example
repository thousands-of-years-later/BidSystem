# 应用环境：dev、test 或 prod。
APP_ENV=dev

# Docker Compose 使用的开发环境配置。
POSTGRES_DB=bid_system
POSTGRES_USER=bid_system
POSTGRES_PASSWORD=bid_system_dev
POSTGRES_PORT=5432
TZ=Asia/Shanghai

# Python 后端在宿主机运行时使用。
DATABASE_URL=postgresql+psycopg://bid_system:bid_system_dev@localhost:5432/bid_system
# 集成测试必须使用独立数据库，测试夹具会拒绝与 DATABASE_URL 相同的地址。
TEST_DATABASE_URL=postgresql+psycopg://bid_system:bid_system_dev@localhost:5432/bid_system_test

# Python 后端以后也放进同一个 Compose 网络时，主机名应使用服务名 postgres。
DATABASE_URL_DOCKER=postgresql+psycopg://bid_system:bid_system_dev@postgres:5432/bid_system
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT_SECONDS=30

# Redis 仅承载队列、缓存、锁和临时状态。
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
REDIS_URL_DOCKER=redis://redis:6379/0
REDIS_MAX_CONNECTIONS=20

# Celery 使用 RabbitMQ 作为 broker；技术失败进入 RabbitMQ 死信队列。
# 正式业务进度和结果由所属业务模块持久化，PostgreSQL 不保存通用任务执行账本。
RABBITMQ_DEFAULT_USER=bid_system
RABBITMQ_DEFAULT_PASS=bid_system_dev
RABBITMQ_DEFAULT_VHOST=/
RABBITMQ_AMQP_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
CELERY_BROKER_URL=amqp://bid_system:bid_system_dev@localhost:5672//
CELERY_BROKER_URL_DOCKER=amqp://bid_system:bid_system_dev@rabbitmq:5672//
WORKER_QUEUE_NAME=bid-system
WORKER_CONCURRENCY=2
WORKER_SOFT_TIME_LIMIT_SECONDS=300
WORKER_HARD_TIME_LIMIT_SECONDS=330
WORKER_MAX_RETRIES=3
WORKER_RETRY_BASE_DELAY_SECONDS=5
WORKER_RETRY_MAX_DELAY_SECONDS=300
WORKER_PREFETCH_MULTIPLIER=1
WORKER_DEAD_LETTER_QUEUE_NAME=bid-system.dead
WORKER_DELIVERY_LIMIT=5

# MinIO 对象存储（仅用于本地开发）。
MINIO_ROOT_USER=bid_system
MINIO_ROOT_PASSWORD=bid_system_dev_secret
MINIO_BUCKET=bid-system
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# Python 后端在宿主机运行时使用。
MINIO_ENDPOINT=localhost:9000
MINIO_SECURE=false

# Python 后端在 Compose 网络中运行时使用。
MINIO_ENDPOINT_DOCKER=minio:9000

# 文档安全扫描和Office转PDF。ClamAV的StreamMaxLength配置为211MiB。
CLAMAV_PORT=3310
DOCUMENT_CLAMAV_HOST=localhost
DOCUMENT_CLAMAV_PORT=3310
DOCUMENT_CLAMAV_TIMEOUT_SECONDS=300
DOCUMENT_LIBREOFFICE_EXECUTABLE=libreoffice
DOCUMENT_CONVERSION_TIMEOUT_SECONDS=120
DOCUMENT_UPLOAD_REQUEST_BODY_BYTES=210763776

# 可选 LLM/OCR 客户端。启用时必须从环境或密钥系统注入完整配置。
LLM_ENABLED=false
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_PROBE_ON_STARTUP=false

OCR_ENABLED=false
OCR_BASE_URL=
OCR_API_KEY=
OCR_MODEL=
OCR_PROBE_ON_STARTUP=false

# 外部调用与生命周期超时，单位均为秒。
HTTP_TIMEOUT_SECONDS=30
STARTUP_CONNECT_TIMEOUT_SECONDS=10
SHUTDOWN_TIMEOUT_SECONDS=10

LOG_LEVEL=INFO
LOG_JSON=false

# OpenTelemetry默认关闭；启用任一信号时必须配置Collector的OTLP HTTP基础地址。
TRACING_ENABLED=false
TRACING_SERVICE_NAME=bid-system
TRACING_OTLP_ENDPOINT=
METRICS_ENABLED=false
METRICS_EXPORT_INTERVAL_SECONDS=60

# 安全默认关闭。启用时私钥必须由密钥系统注入，公钥环使用JSON数组以支持kid轮换。
AUTH_ENABLED=false
JWT_ALGORITHM=RS256
JWT_ACTIVE_KEY_ID=
JWT_SIGNING_PRIVATE_KEY=
JWT_VERIFICATION_KEYS=[]
JWT_ISSUER=bid-system
JWT_AUDIENCE=bid-system-api
JWT_ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_ABSOLUTE_TTL_SECONDS=2592000
REFRESH_TOKEN_IDLE_TTL_SECONDS=604800
REFRESH_COOKIE_SECURE=true
ARGON2_MEMORY_COST_KIB=19456
ARGON2_TIME_COST=2
ARGON2_PARALLELISM=1
# AUTH_ENABLED=true 时以下两项必填。密码只用于首次创建经理，不会写入日志。
AUTH_DEFAULT_TENANT_ID=default
INITIAL_MANAGER_USERNAME=
INITIAL_MANAGER_PASSWORD=

# HTTP API 暴露策略及传输限制。列表值使用 JSON 数组格式。
API_TITLE=Bid System API
API_DESCRIPTION=HTTP API for the bid agent platform.
API_PREFIX=/api/v1
API_CORS_ORIGINS=[]
API_TRUSTED_HOSTS=["localhost","127.0.0.1"]
API_GZIP_MINIMUM_SIZE_BYTES=1024
API_MAX_REQUEST_BODY_BYTES=10485760
API_READINESS_TIMEOUT_SECONDS=3
API_HSTS_ENABLED=false
